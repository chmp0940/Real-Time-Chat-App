{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && npm run copy-migrations",
    "copy-migrations": "node -e \"const fs=require('fs');const path=require('path');const src=path.join('src','migrations');const dest=path.join('dist','migrations');fs.mkdirSync(dest,{recursive:true});fs.readdirSync(src).filter(f=>f.endsWith('.sql')).forEach(f=>fs.copyFileSync(path.join(src,f),path.join(dest,f)));console.log('Migrations copied to dist/')\"",
    "start": "node dist/server.js",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:prod": "node dist/db/migrate.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@clerk/express": "^2.0.11",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "helmet": "^8.1.0",
    "multer": "^2.2.0",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "tsx": "^4.21.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.2.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
